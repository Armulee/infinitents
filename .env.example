# ── Supabase ──────────────────────────────────────────────────────────────────
# Project URL + anon key (Dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service-role key — server only. Used by the job worker and seed script.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Shared secret protecting worker/cron endpoints (POST /api/jobs/*)
CRON_SECRET=generate-a-long-random-string

# ── AI Providers (all optional — stages without a key fall back to the
#    deterministic mock provider so the whole pipeline runs in development) ────
# Text / reasoning
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=
# Image
BFL_API_KEY=                # Flux (Black Forest Labs)
# Video
SEEDANCE_API_KEY=           # Seedance 2.0 (BytePlus ModelArk)
SEEDANCE_API_URL=https://ark.ap-southeast.bytepluses.com/api/v3
VEO_API_KEY=
KLING_API_KEY=

# Optional external render service for final MP4 assembly (see docs/rendering)
RENDER_SERVICE_URL=
RENDER_SERVICE_TOKEN=

# ── Platform OAuth (Publishing) — optional, mock connections work without ─────
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
